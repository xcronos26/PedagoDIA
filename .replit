modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 90000

[userenv]

[userenv.shared]
JWT_SECRET = "pedagogia-0e971b7eeeb029a52c5b5586da85afc91fb238290bbc74ba9f5af2bbd107ef11"

[nix]
channel = "stable-25_05"
