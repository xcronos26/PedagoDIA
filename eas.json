{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "projectRoot": "artifacts/mobile",
      "developmentClient": true,
      "distribution": "internal",
      "node": "20",
      "pnpm": "10",
      "env": {
        "EXPO_USE_PNPM": "1"
      }
    },
    "preview": {
      "projectRoot": "artifacts/mobile",
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "node": "20",
      "pnpm": "10",
      "env": {
        "EXPO_USE_PNPM": "1"
      }
    },
    "production": {
      "projectRoot": "artifacts/mobile",
      "android": {
        "buildType": "app-bundle"
      },
      "node": "20",
      "pnpm": "10",
      "env": {
        "EXPO_USE_PNPM": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
